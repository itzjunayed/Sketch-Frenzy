# Backend Environment Variables
# Copy this file to .env and fill in your values

# Server port
PORT=5000

# Redis connection URL
# Local: redis://localhost:6379
# Redis Cloud: redis://:<password>@<host>:<port>
REDIS_URL=redis://localhost:6379

# PostgreSQL connection URL (optional — game works without it)
# Format: postgresql://user:password@host:5432/dbname
DATABASE_URL=postgresql://postgres:password@localhost:5432/sketchfrenzy

# Set to "true" if your Postgres host uses SSL (e.g. Railway, Render)
DB_SSL=false

# Frontend URL for CORS (use * for dev)
FRONTEND_URL=http://localhost:5173
